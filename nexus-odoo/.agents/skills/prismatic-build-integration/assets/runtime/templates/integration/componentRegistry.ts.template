// Reference: CNI Component Registry
// This file shows the correct structure for componentRegistry.ts. It is a REFERENCE, not a rendered template.
//
// Manifests are generated by: prismatic-tools install-manifest <component-key>
// They install into src/manifests/<component>/ (a directory, not a JSON file).

import { componentManifests } from "@prismatic-io/spectral";
import slack from "./manifests/slack";

// Do NOT register: webhook-triggers, loop, branch — these are built-in platform components
// that never need manifests. Adding them here will cause build failures.
export const componentRegistry = componentManifests({
  slack,
});

